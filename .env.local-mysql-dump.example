# Local-only MySQL dump settings for scripts/dump-mysql-local.sh.
# Copy this file to .env.local-mysql-dump and fill values from DataGrip.
# .env.local-mysql-dump is ignored by git.

# Required: values from your DataGrip connection.
MYSQL_DUMP_HOST=127.0.0.1
MYSQL_DUMP_PORT=3306
MYSQL_DUMP_DATABASE=kim_math
MYSQL_DUMP_USER=kim_math_app
MYSQL_DUMP_PASSWORD=

# Optional: where local dumps are written.
# Relative paths are resolved from the repository root.
MYSQL_DUMP_OUTPUT_DIR=local-mysql-dumps

# Optional: keep local dump files for this many days.
MYSQL_DUMP_RETENTION_DAYS=30

# Optional: add extra mysqldump flags, space-separated.
# Common for some MySQL 8 client/server combinations:
# MYSQL_DUMP_EXTRA_ARGS=--column-statistics=0
MYSQL_DUMP_EXTRA_ARGS=

# Optional: use a MySQL option file instead of MYSQL_DUMP_PASSWORD.
# MYSQL_DUMP_DEFAULTS_FILE=/absolute/path/to/mysql-client.cnf

# Optional: open an SSH tunnel before dumping.
# Use this when DataGrip connects through SSH.
# MYSQL_DUMP_SSH_HOST=example.com
# MYSQL_DUMP_SSH_USER=suhui
# MYSQL_DUMP_SSH_PORT=22
# MYSQL_DUMP_SSH_KEY=/Users/you/.ssh/id_ed25519
# MYSQL_DUMP_REMOTE_HOST=127.0.0.1
# MYSQL_DUMP_REMOTE_PORT=3306
# MYSQL_DUMP_LOCAL_PORT=33306

# Optional: temporarily skip the pre-push dump.
# MYSQL_DUMP_SKIP=1
